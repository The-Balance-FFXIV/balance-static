 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: left">
&lt;div class="md__image">
 &lt;img id="[272 31 42 355 63 460]" src="https://beta.xivapi.com/api/1/asset/ui/icon/002000/002076_hr1.tex?format=png" onclick="openModal(this.id)" alt="Lance Barrage" />
