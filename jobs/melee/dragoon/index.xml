 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: left">
&lt;div class="md__image">
 &lt;img id="[249 380 497 167 233 369]" src="https://beta.xivapi.com/api/1/asset/ui/icon/002000/002076_hr1.tex?format=png" onclick="openModal(this.id)" alt="Lance Barrage" />
