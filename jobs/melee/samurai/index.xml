 &lt;/tr>
 &lt;tr>
 &lt;td style="text-align: left">
&lt;div class="md__image">
 &lt;img id="[327 491 124 366 339 377]" src="https://xivapi.com/i/003000/003174_hr1.png" onclick="openModal(this.id)" alt="Hissatsu: Kyuten" />
&lt;/div>
&lt;/td>
