 &lt;tr>
 &lt;td style="text-align: left">
&lt;div class="md__image">
 &lt;img id="[105 54 3 492 481 377]" src="https://xivapi.com/i/003000/003177_hr1.png" onclick="openModal(this.id)" alt="Hissatsu: Guren" />
