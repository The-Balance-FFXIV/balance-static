 &lt;tr>
 &lt;td style="text-align: left">
&lt;div class="md__image">
 &lt;img id="[111 357 298 136 387 29]" src="https://xivapi.com/i/003000/003174_hr1.png" onclick="openModal(this.id)" alt="Hissatsu: Kyuten" />
